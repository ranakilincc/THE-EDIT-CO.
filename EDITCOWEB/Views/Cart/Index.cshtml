@model IEnumerable<dynamic>
@{
    Layout = "_Layout";
    ViewData["Title"] = "Sepetim";
}

<div class="container" style="margin-top: 80px; min-height: 400px;">
    <h2 style="margin-bottom: 5px; font-weight: 300;">ALIŞVERİŞ SEPETİNİZ</h2>

    @if (Model != null && Model.Any())
    {
        <!-- SEPET DOLU -->
        <div id="sepet-dolu">
            <table class="table table-hover" style="width: 100%; border-collapse: separate; border-spacing: 0 15px;">
                <thead>
                    <tr style="background-color: #f8f9fa; text-align: left;">
                        <th style="width: 60%; padding: 15px; color: #555;">Ürün</th>
                        <th style="width: 20%; padding: 15px; color: #555;">Fiyat</th>
                        <th style="width: 20%; padding: 15px; color: #555; text-align: center;">İşlem</th>
                    </tr>
                </thead>
                <tbody id="sepet-listesi">
                    @foreach (var urun in Model)
                    {
                        <tr style="border-bottom: 1px solid #eee;">
                            <td style="padding: 15px; display: flex; align-items: center; gap: 20px;">
                                <img src="@urun.ResimYolu" style="width: 80px; height: 80px; object-fit: cover; border-radius: 8px; border: 1px solid #ddd;" onerror="this.src='/images/yok.png'">
                                <span style="font-weight: 600; font-size: 1.1rem; color: #333;">@urun.ProductName</span>
                            </td>
                            <td style="padding: 15px; vertical-align: middle; font-size: 1.1rem; color: #555;">
                                @urun.Price TL x @urun.Quantity
                            </td>
                            <td style="padding: 15px; vertical-align: middle; text-align: center;">
                                <button onclick="urunuVeritabanindanSil(@urun.CartId)" style="background: none; border: none; color: #dc3545; font-size: 1.5rem; cursor: pointer;">
                                    <i class="fa-solid fa-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 30px; padding: 0 10px;">
                <button onclick="sepetiVeritabanindanBosalt()" class="btn" style="background-color: #e0a6aa; color: black; padding: 12px 40px; border-radius: 30px; border: none; font-size: 1.1rem; font-weight: bold; cursor: pointer; box-shadow: 0 4px 6px rgba(224, 166, 170, 0.3);">
                    Sepeti Temizle
                </button>

                <div style="display: flex; align-items: center; gap: 20px;">
                    <div class="coupon-section" style="padding: 15px; border: 1px dashed #e0a6aa; border-radius: 10px;">
                        <label style="display: block; margin-bottom: 10px; font-weight: bold; color: #555;">İndirim Kuponunuz mu var?</label>
                        <div style="display: flex; gap: 10px;">
                            <input type="text" id="couponCode" placeholder="KOD GİRİN..." style="flex-grow: 1; padding: 10px; border: 1px solid #ddd; border-radius: 5px; text-transform: uppercase;">
                            <button type="button" onclick="applyCoupon()" style="background-color: #e0a6aa; color: white; border: none; padding: 10px 20px; border-radius: 5px; cursor: pointer; font-weight: bold;">Uygula</button>
                        </div>
                        <div id="couponMessage" style="margin-top: 10px; font-size: 0.9rem; font-weight: bold;"></div>
                    </div>

                    <h4 style="margin: 0; color: black;">
                        Toplam: <span id="sepet-toplam" style="color: black; font-weight: bold; font-size: 1.4rem;">@Model.Sum(x => (decimal)x.TotalPrice) TL</span>
                    </h4>

                    <a href="javascript:void(0);" onclick="odemeSayfasinaGit()" class="btn" style="background-color: #e0a6aa; color: black; padding: 12px 40px; border-radius: 30px; border: none; font-size: 1.1rem; font-weight: bold; text-decoration: none; box-shadow: 0 4px 6px rgba(224, 166, 170, 0.3);">
                        Ödemeye Geç
                    </a>
                </div>
            </div>
        </div>
    }
    else
    {
        <!-- SEPET BOŞ -->
        <div id="sepet-bos" style="text-align: center; padding: 60px;">
            <i class="fa-solid fa-basket-shopping" style="font-size: 60px; color: black; margin-bottom: 20px;"></i>

            @{
                // O an giriş yapmış kullanıcının adını Session'dan çekiyoruz
                var userName = Context.Session.GetString("FirstName");
                var displayName = !string.IsNullOrEmpty(userName) ? userName : "Değerli Müşterimiz";
            }

            <!-- margin-bottom ekleyerek butonla arasına boşluk koyduk -->
            <p style="font-size: 18px; color:black; margin-bottom: 30px;">Sepetinizde henüz ürün yok, @displayName.</p>

            <!-- display: inline-block ekleyerek butonun üstteki yazıya taşmasını engelledik -->
            <a href="/#urunler" class="btn" style="display: inline-block; background-color: #e0a6aa; color: black; border-radius: 30px; padding: 15px 50px; font-weight: bold; text-decoration: none; box-shadow: 0 5px 15px rgba(224, 166, 170, 0.4);">
                Alışverişe Başla
            </a>
        </div>
    }
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    // Ürün Silme Fonksiyonu (Veritabanı için hazır yapı)
    function urunuVeritabanindanSil(cartId) {
        if(confirm("Bu ürünü sepetten çıkarmak istiyor musun?")) {
             $.post("/Cart/Delete", { id: cartId }, function (data) {
                if (data.success) {
                    location.reload();
                } else {
                    alert("Hata: " + data.message);
                }
            });
        }
    }

    // Sepeti Boşaltma Fonksiyonu
    function sepetiVeritabanindanBosalt() {
        if(confirm("Tüm sepeti temizlemek istediğine emin misin?")) {
             $.post("/Cart/Clear", function (data) {
                if (data.success) {
                    location.reload();
                }
            });
        }
    }

        function odemeSayfasinaGit() {
        const toplamSpan = document.getElementById("sepet-toplam");
        if (!toplamSpan) return;

        let sonFiyat = "";
        const indirimliSpan = toplamSpan.querySelector("span");

        if (indirimliSpan) {
            sonFiyat = indirimliSpan.innerText;
        } else {
            sonFiyat = toplamSpan.innerText.split("TL")[0];
        }

        // --- BURAYI DEĞİŞTİRİYORUZ ---
        // Rakam içindeki TL yazısını ve boşlukları at.
        // Replace işleminde NOKTAYI SİLMEYELİM, sadece varsa virgülü noktaya çevirelim.
        // Çünkü JavaScript ondalıklı sayılarda (buçuklu) noktayı kullanır (Örn: 667.5)
        let temizFiyat = sonFiyat.replace("TL", "").replace(",", ".").trim();

        // ... geri kalan kodlar aynı kalacak ...
        localStorage.setItem("odenecekTutar", temizFiyat);
        localStorage.setItem("indirimliToplam", temizFiyat);

        window.location.href = "/Checkout/Index";
    }

        function applyCoupon() {
        var code = document.getElementById("couponCode").value;
        var messageDiv = document.getElementById("couponMessage");
        var toplamSpan = document.getElementById("sepet-toplam");

        if (code === "") {
            messageDiv.style.color = "red";
            messageDiv.innerText = "Lütfen bir kod giriniz!";
            return;
        }

        $.post("/Cart/CheckCoupon", { code: code }, function (data) {
            if (data.success) {
                    // Rakamın içindeki noktaları ve virgülleri temizleyip gerçek bir sayıya çeviriyoruz
    let hamMetin = toplamSpan.innerText.replace("TL", "").replace(/\./g, "").replace(",", ".").trim();
    let mevcutToplam = parseFloat(hamMetin);
                if (mevcutToplam < data.minLimit) {
                    messageDiv.style.color = "orange";
                    messageDiv.innerText = "Bu kupon için sepet en az " + data.minLimit + " TL olmalı!";
                    return;
                }
                messageDiv.style.color = "green";
                messageDiv.innerText = data.message;
                let indirimMiktari = (mevcutToplam * data.discountPercent) / 100;
                let yeniToplam = mevcutToplam - indirimMiktari;
                toplamSpan.innerHTML = `<del style='color:gray;'>${mevcutToplam} TL</del> <span style='color:black;'>${yeniToplam} TL</span>`;
                localStorage.setItem("indirimliToplam", yeniToplam);
            } else {
                messageDiv.style.color = "red";
                messageDiv.innerText = data.message;
            }
        });
    }
</script>