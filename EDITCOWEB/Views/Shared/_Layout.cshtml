@using Microsoft.AspNetCore.Http
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - The Edit Co.</title>

    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <style>
        /* Toast Kutusu CSS */
        #toast-kutusu {
            visibility: hidden;
            min-width: 250px;
            background-color: #333;
            color: #fff;
            text-align: center;
            border-radius: 50px;
            padding: 16px;
            position: fixed;
            z-index: 1000;
            left: 50%;
            bottom: 30px;
            transform: translateX(-50%);
            font-size: 16px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.3);
            opacity: 0;
            transition: opacity 0.5s, bottom 0.5s;
        }

            #toast-kutusu.goster {
                visibility: visible;
                opacity: 1;
                bottom: 50px;
                background-color: #e0a6aa;
            }

        /* --- YENİ EKLENEN FİLTRE MENÜSÜ CSS --- */
        .mega-menu-kutu {
            display: none; /* Başlangıçta gizli - Head içinde olduğu için anında uygulanır */
            position: absolute;
            top: 100%;
            left: 0;
            width: 500px;
            background-color: #fffdfd;
            padding: 25px;
            z-index: 9999;
            border-radius: 8px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.08);
            border: 1px solid #f2e6e6;
            margin-top: 15px;
        }

            .mega-menu-kutu.goster {
                display: block;
            }

        .filtre-baslik {
            font-family: 'Times New Roman', serif;
            color: #4a3b3b;
            margin-bottom: 12px;
            font-size: 1.05rem;
            border-bottom: 1px solid #f2e6e6;
            padding-bottom: 5px;
        }

        .custom-checkbox {
            margin-bottom: 6px;
        }

            .custom-checkbox input {
                accent-color: #e0a6aa;
                cursor: pointer;
                margin-right: 5px;
            }

            .custom-checkbox label {
                font-size: 0.9rem;
                color: #555;
                cursor: pointer;
                font-family: 'Inter', sans-serif;
            }

        .fiyat-input {
            width: 80px;
            text-align: center;
            border: 1px solid #e0d4d4;
            border-radius: 4px;
            padding: 5px;
            outline: none;
            font-family: 'Inter', sans-serif;
            font-size: 0.9rem;
        }

            .fiyat-input:focus {
                border-color: #e0a6aa;
            }

        .btn-sonuclarigoster {
            background-color: #e0a6aa;
            color: #fff;
            border: none;
            border-radius: 4px;
            width: 100%;
            padding: 10px;
            font-family: 'Inter', sans-serif;
            font-weight: 500;
            transition: background-color 0.3s;
            cursor: pointer;
        }

            .btn-sonuclarigoster:hover {
                background-color: #d4989c;
            }
    </style>
</head>
<body>

    <header class="navbar">
        <div class="nav-left" style="display: flex; align-items: center;">
            <a href="/">Anasayfa</a>

            <div id="urunlerDropdownKapsayici" style="position: relative; display: inline-block;">
                <a href="#" id="urunlerMenuButonu" style="cursor: pointer;">
                    Ürünler <i class="fas fa-chevron-down" style="font-size: 0.6em; margin-left: 3px; vertical-align: middle;"></i>
                </a>

                <div id="filtreMegaMenu" class="mega-menu-kutu">
                    <form action="/Home/Urunler" method="GET">
                        <div style="display: flex; justify-content: space-between;">

                            <div style="margin-right: 30px;">
                                <h6 class="filtre-baslik">Cilt Tipi</h6>
                                <div class="custom-checkbox"><input type="checkbox" name="ciltTipi" value="Kuru" id="kuru"><label for="kuru">Kuru</label></div>
                                <div class="custom-checkbox"><input type="checkbox" name="ciltTipi" value="Yağlı" id="yagli"><label for="yagli">Yağlı</label></div>
                                <div class="custom-checkbox"><input type="checkbox" name="ciltTipi" value="Hassas" id="hassas"><label for="hassas">Hassas</label></div>
                                <div class="custom-checkbox"><input type="checkbox" name="ciltTipi" value="Normal" id="normal"><label for="normal">Normal</label></div>
                                <div class="custom-checkbox"><input type="checkbox" name="ciltTipi" value="Karma" id="karma"><label for="karma">Karma</label></div>
                            </div>

                            <div style="margin-right: 30px;">
                                <h6 class="filtre-baslik">Ürün Türü</h6>
                                <div class="custom-checkbox"><input type="checkbox" name="urunTuru" value="Temizleyici" id="temizleyici"><label for="temizleyici">Temizleyici</label></div>
                                <div class="custom-checkbox"><input type="checkbox" name="urunTuru" value="Tonik" id="tonik"><label for="tonik">Tonik</label></div>
                                <div class="custom-checkbox"><input type="checkbox" name="urunTuru" value="Serum" id="serum"><label for="serum">Serum</label></div>
                                <div class="custom-checkbox"><input type="checkbox" name="urunTuru" value="Nemlendirici" id="nemlendirici"><label for="nemlendirici">Nemlendirici</label></div>
                                <div class="custom-checkbox"><input type="checkbox" name="urunTuru" value="Güneş Kremi" id="guneskremi"><label for="guneskremi">Güneş Kremi</label></div>
                            </div>

                            <div style="display: flex; flex-direction: column; justify-content: space-between;">
                                <div>
                                    <h6 class="filtre-baslik">Fiyat Aralığı</h6>
                                    <div style="display: flex; align-items: center;">
                                        <input type="number" class="fiyat-input" name="minFiyat" placeholder="₺0">
                                        <span style="margin: 0 8px; color: #777;">-</span>
                                        <input type="number" class="fiyat-input" name="maxFiyat" placeholder="₺1000">
                                    </div>
                                </div>
                                <button type="submit" class="btn-sonuclarigoster mt-3">Sonuçları Göster</button>
                            </div>

                        </div>
                    </form>
                </div>
            </div>

            <a href="#yeni-gelenler">Yeni Gelenler</a>
            <a href="#kampanyalar">Kampanyalar</a>
            <a href="/cilt-tipi-testi.html" style="color: #e0a6aa; font-weight: bold; margin-left: 15px; text-decoration: none;">
                <i class="fa-solid fa-wand-magic-sparkles"></i> Cilt Tipini Öğren
            </a>
        </div>

        <div class="nav-logo">
            The Edit Co.
        </div>

        <div class="nav-right">
            <a href="/Favorites/Index" style="text-decoration: none; position: relative; margin-right: 15px;">
                <i class="fa-regular fa-heart" style="font-size: 1.5rem; color: #333;"></i>
                <span id="fav-sayisi-badge" style="position: absolute; top: -10px; right: -8px; background-color: #e0a6aa; color: white; font-size: 0.7rem; font-weight: bold; border-radius: 50%; width: 17px; height: 17px; display: flex; align-items: center; justify-content: center; display: none;">0</span>
            </a>
            <a href="/Cart/Index" style="position: relative; display: inline-block; text-decoration: none; color: black; margin-right: 20px;">
                <i class="bi bi-bag" style="font-size: 1.5rem;"></i>
                <span id="sepet-sayisi" style="position: absolute; top: -5px; right: -8px; background-color: #e0a6aa; color: white; border-radius: 50%; font-size: 11px; font-weight: bold; padding: 2px 6px; box-shadow: 0 2px 5px rgba(0,0,0,0.2);">0</span>
            </a>

            @if (Context.Session.GetString("UserEmail") == null)
            {
                <a href="/Account/Login">Giriş Yap / Üye Ol</a>
            }
            else
            {
                <a href="/Account/Profile">Profilim</a>
                <a href="/Account/Logout">Çıkış</a>
            }
        </div>
    </header>

    <main>
        @RenderBody()
    </main>

    <div id="toast-kutusu"><i class="fa-solid fa-check"></i> Ürün sepete eklendi!</div>

    <script>
        // Sepet Sayısı Güncelleme
        document.addEventListener("DOMContentLoaded", function() {
            var kayitliSayi = localStorage.getItem('sepetSayisi');
            var sepetRozeti = document.getElementById("sepet-sayisi");
            if (kayitliSayi && sepetRozeti) {
                sepetRozeti.innerText = kayitliSayi;
            }
        });

        // Toast Bildirim
        function bildirimGoster(mesaj) {
            var x = document.getElementById("toast-kutusu");
            if (mesaj) x.innerHTML = '<i class="fa-solid fa-check"></i> ' + mesaj;
            x.className = "goster";
            setTimeout(function(){ x.className = x.className.replace("goster", ""); }, 3000);
        }

        // Favori Sayısı Güncelleme
        document.addEventListener("DOMContentLoaded", function() {
            favoriSayaciniGuncelle();
        });

        function favoriSayaciniGuncelle() {
            var favoriler = JSON.parse(localStorage.getItem('favorilerim')) || [];
            var sayi = favoriler.length;
            var rozet = document.getElementById("fav-sayisi-badge");

            if (rozet) {
                rozet.innerText = sayi;
                if (sayi > 0) {
                    rozet.style.display = "flex";
                } else {
                    rozet.style.display = "none";
                }
            }
        }

        // AÇILIR MENÜ (MEGA MENU) MANTIĞI
        document.addEventListener('DOMContentLoaded', function() {
            const urunlerButonu = document.getElementById('urunlerMenuButonu');
            const filtreMenusu = document.getElementById('filtreMegaMenu');

            // "Ürünler" yazısına tıklandığında menüyü aç/kapat
            urunlerButonu.addEventListener('click', function(e) {
                e.preventDefault(); // Sayfanın en üste atlamasını engeller
                filtreMenusu.classList.toggle('goster');
            });

            // Sayfada menü harici boş bir yere tıklandığında menüyü kapat
            document.addEventListener('click', function(e) {
                const kapsayici = document.getElementById('urunlerDropdownKapsayici');
                // Eğer tıklanan yer kapsayıcının (buton veya açılan menü) içinde değilse gizle
                if (!kapsayici.contains(e.target)) {
                    filtreMenusu.classList.remove('goster');
                }
            });

            // Tıklanan checkbox kapanmasın diye menu içine tıklamayı durdur
            filtreMenusu.addEventListener('click', function(e) {
                e.stopPropagation();
            });
        });
    </script>

    
    <div id="chat-circle" onclick="toggleChat()"></div>

    <style>
        #chat-circle {
            position: fixed;
            bottom: 20px;
            right: 20px;
            width: 110px !important; /* Boyutu transparan görsel için ideal hale getirdik */
            height: 110px !important;
            z-index: 9999;
            cursor: pointer;
            transition: all 0.4s ease;
            /* GÖRSEL AYARI */
            /* ÖNEMLİ: Yeni transparan görseli buraya bağladık */
            background-image: url('/images/ai-bot-icon-removebg-preview.png') !important;
            background-repeat: no-repeat !important;
            background-position: center !important;
            background-size: 100% 100% !important; /* contain yerine 100% 100% transparan görselde daha iyi durur */
            background-color: transparent !important;
            border: none !important;
            outline: none !important;
        }

            #chat-circle:hover {
                transform: scale(1.1) translateY(-5px) !important;
            }
    </style>




    <div id="chat-box" style="display: none; position: fixed; bottom: 120px; right: 30px; width: 380px; height: 550px; background: rgba(255, 255, 255, 0.95); backdrop-filter: blur(10px); border-radius: 30px; box-shadow: 0 20px 50px rgba(0,0,0,0.15); z-index: 9999; flex-direction: column; overflow: hidden; border: 1px solid rgba(121, 134, 203, 0.3); /* Lila-Mavi Çerçeve */">

        <div style="background: #7986cb; /* Daha mavi bir lila */ padding: 25px; text-align: left; position: relative; color: white;">
            <div style="display: flex; align-items: center; gap: 10px;">
                <div style="width: 10px; height: 10px; background: #e3f2fd; border-radius: 50%; box-shadow: 0 0 10px #e3f2fd;"></div>
                <span style="font-size: 1rem; font-weight: bold; letter-spacing: 0.5px;">THE EDIT CO. AI</span>
            </div>
            <p style="font-size: 0.75rem; margin-top: 5px; opacity: 0.8; color: #e3f2fd;">Yapay Zeka Uzmanı Çevrimiçi</p>
            <span onclick="toggleChat()" style="position: absolute; top: 20px; right: 20px; cursor: pointer; color: white; font-size: 1.2rem; opacity: 0.7;">✕</span>
        </div>

        <div id="messages" style="flex: 1; padding: 20px; overflow-y: auto; background: #ffffff;">
            <div style="margin-bottom: 15px; background: #e3f2fd; /* Buz Mavisi */ padding: 12px 15px; border-radius: 18px 18px 18px 2px; max-width: 85%; font-size: 14px; color: #1a237e; /* Koyu Mavi Yazı */ border: 1px solid #bbdefb;">
                Merhaba! Ben THE EDIT CO. Güzellik Asistanı. Cilt tipine uygun ürünleri bulmana veya siparişinle ilgili soruları yanıtlamaya hazırım. ✨
            </div>
        </div>

        <div style="padding: 15px 20px; border-top: 1px solid #f0f0f0; display: flex; gap: 10px; background: white;">
            <input type="text" id="userInput" placeholder="AI'ya her şeyi sor..." style="flex: 1; border: 1px solid #e0e0e0; padding: 12px 18px; border-radius: 30px; outline: none; font-size: 14px; background: #f9f9f9;">
            <button onclick="sendToAI()" style="background: #7986cb; /* Lila-Mavi */ border: none; width: 45px; height: 45px; border-radius: 50%; color: white; cursor: pointer; display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 10px rgba(121, 134, 203, 0.3);">
                <span style="font-size: 20px; margin-left: 3px;">➤</span>
            </button>
        </div>
    </div>

    <script>
        function toggleChat() {
            const chatBox = document.getElementById('chat-box');
            if (chatBox.style.display === 'none' || chatBox.style.display === '') {
                chatBox.style.display = 'flex';
            } else {
                chatBox.style.display = 'none';
            }
        }

        // Python API'sine mesaj gönderen ve arayüzü yöneten fonksiyon
        async function sendToAI() {
            const input = document.getElementById('userInput');
            const msgDiv = document.getElementById('messages');
            const userText = input.value.trim();

            if (!userText) return; // Boş mesaj gönderilmesini engelle

            // 1. Kullanıcı mesajını ekrana ekle (Toz Pembe Balon)
            msgDiv.innerHTML += `<div style="margin-bottom: 10px; background: #e0a6aa; color: white; padding: 10px; border-radius: 15px; max-width: 80%; margin-left: auto; font-size: 14px;">${userText}</div>`;
            input.value = "";
            msgDiv.scrollTop = msgDiv.scrollHeight;

            // 2. Bekleme (Düşünüyor...) Balonunu Ekle (Lila-Mavi İtalik Yazı)
            const typingId = "typing-" + Date.now();
            msgDiv.innerHTML += `<div id="${typingId}" style="margin-bottom: 15px; background: #e3f2fd; padding: 12px 15px; border-radius: 18px 18px 18px 2px; max-width: 85%; font-size: 14px; color: #7986cb; font-style: italic; border: 1px solid #bbdefb; opacity: 0.8;">✨ AI Düşünüyor...</div>`;
            msgDiv.scrollTop = msgDiv.scrollHeight;

            try {
                // 3. Önce C# veritabanımızdan güncel ürün listesini çekiyoruz
                const dbResponse = await fetch('/Home/BotIcinUrunleriGetir');
                const dbData = await dbResponse.json();
                const veritabaniUrunleri = dbData.urunler;

                // 4. Python sunucusuna BAĞLANIYORUZ (Hem soruyu hem ürünleri gönderiyoruz)
                const response = await fetch('http://127.0.0.1:8000/ask', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        question: userText,
                        products: veritabaniUrunleri
                    })
                });

                const data = await response.json();

                // 5. "Düşünüyor..." balonunu sil
                document.getElementById(typingId).remove();

               // 6. Gelen cevabı estetik hale getir
                let formattedAnswer = data.answer
                // Yapay zeka doğru formatta (Markdown) verirse:
                .replace(/\[(.*?)\]\((.*?)\)/g, '<a href="$2" style="color: #c2185b; font-weight: bold; text-decoration: underline;" target="_blank">$1</a>')

                // YENİ: Yapay zeka tembellik edip düz link (/Home/ProductDetail/1016) verirse onu şık bir butona çevir:
                .replace(/(\/Home\/ProductDetail\/\d+)/g, '<br><a href="$1" style="color: #c2185b; font-weight: bold; text-decoration: none; background-color: #fce4ec; padding: 4px 10px; border-radius: 12px; display: inline-block; margin-top: 5px; border: 1px solid #f8bbd0;" target="_blank">Ürünü İncele ✨</a>')

                // Eski kodlar aynı kalıyor:
                .replace(/\*\*(.*?)\*\*/g, '<strong style="color: #1a237e;">$1</strong>')
                .replace(/\n/g, '<br>')
                .replace(/<br>\s*\*/g, '<br>&nbsp;&nbsp;•')
                .replace(/^\s*\*/, '&nbsp;&nbsp;•');

                // 7. AI cevabını ekrana bas (Buz Mavisi Balon)
                msgDiv.innerHTML += `<div style="margin-bottom: 15px; background: #e3f2fd; padding: 12px 15px; border-radius: 18px 18px 18px 2px; max-width: 85%; font-size: 14px; color: #1a237e; border: 1px solid #bbdefb; line-height: 1.6;">${formattedAnswer}</div>`;

            } catch (error) {
                // Hata olursa "Düşünüyor" balonunu silip uyarı ver (Eksik olan kısım burasıydı!)
                document.getElementById(typingId).remove();
                msgDiv.innerHTML += `<div style="margin-bottom: 10px; background: #fee; color: red; padding: 10px; border-radius: 15px; font-size: 12px;">Bağlantı koptu, tekrar dener misin?</div>`;
            }

            msgDiv.scrollTop = msgDiv.scrollHeight;
        }
    </script>

</body>
</html>