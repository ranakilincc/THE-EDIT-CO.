<section id="kampanyalar" class="section container py-5">
	<h2 class="text-center mb-4" id="kampanyalar">Kampanyalar</h2>
	<div id="slider-kapsayici" style="width: 100%; margin: 0 auto; overflow: hidden; position: relative; border-radius: 20px;">

		<div id="slider-serit" style="display: flex; width: 100%; transition: transform 1s ease-in-out;">

			@if (ViewBag.Kampanyalar != null && ViewBag.Kampanyalar.Count > 0)
			{
				// Veritabanındaki aktif kampanyaları tek tek dönüp ekrana basıyoruz
				foreach (var kampanya in ViewBag.Kampanyalar)
				{
					<a href="#" style="min-width: 100%; display: block;">
						<img src="@kampanya.ResimYolu" style="width: 100%; height: 450px; object-fit: cover; object-position: center; display: block;" alt="@kampanya.Baslik">
					</a>
				}
			}
			else
			{
				// Eğer admin panelinden henüz hiç kampanya eklenmemişse veya hepsi pasifse, site boş durmasın diye eski resimlerinden birini varsayılan olarak gösteriyoruz
				<a href="#" style="min-width: 100%; display: block;">
					<img src="~/images/kampanya/nemlendiricilerkampanya.png" style="width: 100%; height: 450px; object-fit: cover; object-position: center; display: block;" alt="The Edit Co. Kampanyaları">
				</a>
			}

		</div>
	</div>
</section>

<script>
	//kampanyalar sliderı
	document.addEventListener("DOMContentLoaded", function() {
		// 1. Gerekli elementleri seçiyoruz
		var serit = document.getElementById("slider-serit");
		var slaytlar = serit.getElementsByTagName("a"); // Resimler 'a' etiketi içinde
		var toplamSlayt = slaytlar.length;
		var aktifSlayt = 0; // Başlangıçta 0. slayt (ilk resim)

		// 2. Slayt Değiştirme Fonksiyonu
		function slaytDegistir() {
			aktifSlayt++; // Sıradaki slayta geç

			// Eğer son slayta geldiysek, başa (0'a) dön
			if (aktifSlayt >= toplamSlayt) {
				aktifSlayt = 0;
			}

			// Şeridi sola doğru kaydır (%0, -%100, -%200...)
			var kaydirmaMiktari = -(aktifSlayt * 100);
			serit.style.transform = "translateX(" + kaydirmaMiktari + "%)";
		}

		// 3. Zamanlayıcıyı Başlat (3000ms = 3 Saniye yaptık, daha akıcı olacak!)
		setInterval(slaytDegistir, 3000);
	});
</script>

<script>
	//filtreleme menüsünün açılıp kapanması ile ilgili bir kod//
	function menuyuAcKapat() {
		var menu = document.getElementById("filtre-dropdown");
		if (menu) {
			menu.classList.toggle("show");
		} else {
			console.error("Hata: 'filtre-dropdown' id'li kutu bulunamadı.");
		}
	}
</script>


<script>
	function sepeteEkle(tiklananButon) {
		var resim, ad, fiyat;

		// YENİ YÖNTEM: Butonun üzerindeki gizli verileri (data-) oku
		if (tiklananButon.dataset.ad && tiklananButon.dataset.resim) {
			ad = tiklananButon.dataset.ad;
			resim = tiklananButon.dataset.resim;
			fiyat = tiklananButon.dataset.fiyat;
		}
		// ESKİ YÖNTEM: Kart yapısından bul (Anasayfa için)
		else {
			var urunKutusu = tiklananButon.closest('.urun-kutusu, .card, .col');
			if (urunKutusu) {
				var resimEl = urunKutusu.querySelector('img');
				var adEl = urunKutusu.querySelector('h4, h5, .card-title');
				var fiyatEl = urunKutusu.querySelector('.fiyat, .price, span b');

				resim = resimEl ? resimEl.src : "";
				ad = adEl ? adEl.innerText : "";
				fiyat = fiyatEl ? fiyatEl.innerText : "";
			}
		}

		// Eğer veriler boş geldiyse hata var demektir
		if (!ad || !resim) {
			alert("HATA: Ürün bilgileri okunamadı! F12 Console'a bak.");
			console.log("Gelen veriler:", { ad, resim, fiyat });
			return;
		}

		// Sepete Ekleme İşlemi
		var yeniUrun = { resim: resim, ad: ad, fiyat: fiyat, adet: 1 };
		var sepet = JSON.parse(localStorage.getItem('sepetim')) || [];
		sepet.push(yeniUrun);
		localStorage.setItem('sepetim', JSON.stringify(sepet));
		localStorage.setItem('sepetSayisi', sepet.length);

		// Bildirim ve Güncelleme
		guncelleSepetSayisi();
		alert("Sepete eklendi!");
	}

</script>





