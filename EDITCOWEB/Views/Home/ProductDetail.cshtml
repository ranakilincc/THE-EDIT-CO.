@model EDITCOWEB.Models.Product
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@Model.UrunAdi | The Edit Co.</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <style>
        body {
            font-family: 'Segoe UI', sans-serif;
            margin: 0;
            padding: 20px;
            background-color: #f9f9f9;
            color: #333;
        }

        .geri-don {
            display: inline-block;
            margin-bottom: 20px;
            text-decoration: none;
            color: #555;
            font-weight: bold;
        }

        .urun-kapsayici {
            max-width: 900px;
            margin: 0 auto;
            background: white;
            padding: 20px;
            border-radius: 10px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
            display: flex;
            gap: 30px;
            flex-wrap: wrap;
        }

        .urun-gorsel {
            flex: 1;
            min-width: 300px;
        }

            .urun-gorsel img {
                width: 100%;
                border-radius: 10px;
                border: 1px solid #eee;
                object-fit: cover;
            }

        .urun-bilgi {
            flex: 1;
            min-width: 300px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        h1 {
            font-size: 2rem;
            margin-bottom: 10px;
            color: #222;
        }

        .fiyat {
            font-size: 1.8rem;
            color: #e0a6aa;
            font-weight: bold;
            margin-bottom: 20px;
        }

        .aciklama {
            line-height: 1.6;
            color: #666;
            margin-bottom: 30px;
        }

        .sepete-ekle-btn {
            background-color: #e0a6aa;
            color: white;
            padding: 15px 30px;
            border: none;
            border-radius: 30px;
            font-size: 1.1rem;
            font-weight: bold;
            cursor: pointer;
            transition: transform 0.2s, background 0.3s;
            box-shadow: 0 4px 10px rgba(224, 166, 170, 0.4);
        }

            .sepete-ekle-btn:hover {
                background-color: #c9858a;
                transform: scale(1.05);
            }

        #toast-kutusu {
            visibility: hidden;
            min-width: 250px;
            background-color: #333;
            color: #000;
            text-align: center;
            border-radius: 50px;
            padding: 16px;
            position: fixed;
            z-index: 1000;
            left: 50%;
            bottom: 30px;
            transform: translateX(-50%);
            font-size: 16px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.3);
            opacity: 0;
            transition: opacity 0.5s, bottom 0.5s;
        }

            #toast-kutusu.goster {
                visibility: visible;
                opacity: 1;
                bottom: 50px;
                background-color: #e0a6aa;
            }

        @@media (max-width: 768px) {
            .urun-kapsayici {
                flex-direction: column;
            }
        }

        }
    </style>
</head>
<body>

    <a href="/" class="geri-don"><i class="fa-solid fa-arrow-left"></i> Ana Sayfaya Dön</a>

    <div class="urun-kapsayici">
        <div class="urun-gorsel">
            <img id="u-resim" src="@Model.ResimYolu" alt="@Model.UrunAdi">
        </div>
        <div class="urun-bilgi">
            <h1 id="u-baslik">@Model.UrunAdi</h1>
            <div id="u-fiyat" class="fiyat">@Model.Fiyat.ToString("N0") TL</div>
            <p id="u-aciklama" class="aciklama">@Model.Aciklama</p>

            <button onclick="favoriyeEkle()" onmouseover="this.style.backgroundColor='#c48b90'; this.style.transform='translateY(-3px)';" onmouseout="this.style.backgroundColor='#e0a6aa'; this.style.transform='translateY(0)';" class="btn" style="width: 100%; margin-bottom: 15px; background-color: #e0a6aa; color: white; border: none; padding: 15px 0; border-radius: 30px; font-size: 1.1rem; font-weight: bold; cursor: pointer; transition: all 0.3s; display: flex; align-items: center; justify-content: center; gap: 10px; box-shadow: 0 4px 6px rgba(224, 166, 170, 0.2);">
                <i id="fav-ikon" class="fa-regular fa-heart"></i>
                <span>Favorilere Ekle</span>
            </button>

            <button class="sepete-ekle-btn" onclick="sepeteEkle()">Sepete Ekle</button>
        </div>
    </div>

    <div id="toast-kutusu"><i class="fa-solid fa-check"></i> Ürün sepete eklendi!</div>

    <script>
        // Bildirim Fonksiyonu
        function bildirimGoster(mesaj) {
            var x = document.getElementById("toast-kutusu");
            if (mesaj) x.innerHTML = '<i class="fa-solid fa-check"></i> ' + mesaj;
            x.className = "goster";
            setTimeout(function () { x.className = x.className.replace("goster", ""); }, 3000);
        }

        // Sepete Ekleme Fonksiyonu (Artık C# Modelinden doğrudan veri alıyor)
        function sepeteEkle() {
            var sepet = JSON.parse(localStorage.getItem('sepetim')) || [];
            sepet.push({
                ad: "@Html.Raw(Model.UrunAdi)",
                resim: "@Html.Raw(Model.ResimYolu)",
                fiyat: "@Html.Raw(Model.Fiyat.ToString("N0")) TL",
                adet: 1
            });
            localStorage.setItem('sepetim', JSON.stringify(sepet));
            localStorage.setItem('sepetSayisi', sepet.length);
            bildirimGoster("Ürün başarıyla sepete eklendi!");
        }

        // Favorilere Ekleme Fonksiyonu (C# Modelinden veri alıyor)
        function favoriyeEkle() {
            var favoriler = JSON.parse(localStorage.getItem('favorilerim')) || [];
            var baslik = "@Html.Raw(Model.UrunAdi)";

            var varMi = favoriler.find(x => x.ad === baslik);
            if (varMi) {
                bildirimGoster("Bu ürün zaten favorilerinizde ekli! ❤️");
                return;
            }

            favoriler.push({
                ad: baslik,
                resim: "@Html.Raw(Model.ResimYolu)",
                fiyat: "@Html.Raw(Model.Fiyat.ToString("N0")) TL"
            });

            localStorage.setItem('favorilerim', JSON.stringify(favoriler));
            setTimeout(function () { bildirimGoster("Favorilere eklendi! ❤️"); }, 100);
        }
    </script>
</body>
</html>
