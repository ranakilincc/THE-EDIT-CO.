@model EDITCOWEB.Models.Product
@using Microsoft.AspNetCore.Http
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@Model.UrunAdi | The Edit Co.</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <style>
        body {
            font-family: 'Segoe UI', sans-serif;
            margin: 0;
            padding: 20px;
            background-color: #f9f9f9;
            color: #333;
        }

        .geri-don {
            display: inline-block;
            margin-bottom: 20px;
            text-decoration: none;
            color: #555;
            font-weight: bold;
        }

        .urun-kapsayici {
            max-width: 900px;
            margin: 0 auto;
            background: white;
            padding: 20px;
            border-radius: 10px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
            display: flex;
            gap: 30px;
            flex-wrap: wrap;
        }

        .urun-gorsel {
            flex: 1;
            min-width: 300px;
        }

            .urun-gorsel img {
                width: 100%;
                border-radius: 10px;
                border: 1px solid #eee;
                object-fit: cover;
            }

        .urun-bilgi {
            flex: 1;
            min-width: 300px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        h1 {
            font-size: 2rem;
            margin-bottom: 10px;
            color: #222;
        }

        .fiyat {
            font-size: 1.8rem;
            color: #e0a6aa;
            font-weight: bold;
            margin-bottom: 20px;
        }

        .aciklama {
            line-height: 1.6;
            color: #666;
            margin-bottom: 30px;
        }

        .sepete-ekle-btn {
            background-color: #e0a6aa;
            color: white;
            padding: 15px 30px;
            border: none;
            border-radius: 30px;
            font-size: 1.1rem;
            font-weight: bold;
            cursor: pointer;
            transition: transform 0.2s, background 0.3s;
            box-shadow: 0 4px 10px rgba(224, 166, 170, 0.4);
        }

            .sepete-ekle-btn:hover {
                background-color: #c9858a;
                transform: scale(1.05);
            }

        #toast-kutusu {
            visibility: hidden;
            min-width: 250px;
            background-color: #333;
            color: #000;
            text-align: center;
            border-radius: 50px;
            padding: 16px;
            position: fixed;
            z-index: 1000;
            left: 50%;
            bottom: 30px;
            transform: translateX(-50%);
            font-size: 16px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.3);
            opacity: 0;
            transition: opacity 0.5s, bottom 0.5s;
        }

            #toast-kutusu.goster {
                visibility: visible;
                opacity: 1;
                bottom: 50px;
                background-color: #e0a6aa;
            }

        @@media (max-width: 768px) {
            .urun-kapsayici {
                flex-direction: column;
            }
        }

        }
    </style>
</head>
<body>

    <a href="/" class="geri-don"><i class="fa-solid fa-arrow-left"></i> Ana Sayfaya Dön</a>

    <div class="urun-kapsayici">
        <div class="urun-gorsel">
            <img id="u-resim" src="@Model.ResimYolu" alt="@Model.UrunAdi">
        </div>
        <div class="urun-bilgi">
            <h1 id="u-baslik">@Model.UrunAdi</h1>
            <div id="u-fiyat" class="fiyat">@Model.Fiyat.ToString("N0") TL</div>
            <p id="u-aciklama" class="aciklama">@Model.Aciklama</p>

            <button onclick="favoriyeEkle()" onmouseover="this.style.backgroundColor='#c48b90'; this.style.transform='translateY(-3px)';" onmouseout="this.style.backgroundColor='#e0a6aa'; this.style.transform='translateY(0)';" class="btn" style="width: 100%; margin-bottom: 15px; background-color: #e0a6aa; color: white; border: none; padding: 15px 0; border-radius: 30px; font-size: 1.1rem; font-weight: bold; cursor: pointer; transition: all 0.3s; display: flex; align-items: center; justify-content: center; gap: 10px; box-shadow: 0 4px 6px rgba(224, 166, 170, 0.2);">
                <i id="fav-ikon" class="fa-regular fa-heart"></i>
                <span>Favorilere Ekle</span>
            </button>

            <button class="sepete-ekle-btn" onclick="sepeteEkle()">Sepete Ekle</button>
        </div>
    </div>

    <div class="yorumlar-kapsayici" style="max-width: 1000px; margin: 40px auto; background: white; padding: 40px; border-radius: 12px; box-shadow: 0 10px 30px rgba(0,0,0,0.05);">

        <h2 style="font-family: 'Playfair Display', serif; color: #222; margin-bottom: 5px; border-bottom: 2px solid #f2e6e6; padding-bottom: 10px;">
            Ürün Değerlendirmeleri
        </h2>

        <div class="yorum-formu" style="margin-bottom: 40px; background: #fcfbfb; padding: 25px; border-radius: 8px; border: 1px solid #f0eaea;">

            @if (Context.Session.GetString("UserEmail") != null)
            {
                <h4 style="margin-bottom: 20px; color: #4a3b3b; font-size: 1.2rem;">Siz de Değerlendirin</h4>

                <form action="/Home/YorumEkle" method="post">
                    <input type="hidden" name="ProductId" value="@Model.Id" />
                    <input type="hidden" name="Puan" id="secilen-puan" value="0" required />

                    <div style="margin-bottom: 20px;">
                        <label style="display: block; margin-bottom: 5px; color: #777; font-size: 0.9rem;">Puanınız *</label>
                        <div class="yildiz-secici" style="font-size: 1.8rem; color: #ddd; cursor: pointer;">
                            <i class="fa-solid fa-star" data-deger="1"></i>
                            <i class="fa-solid fa-star" data-deger="2"></i>
                            <i class="fa-solid fa-star" data-deger="3"></i>
                            <i class="fa-solid fa-star" data-deger="4"></i>
                            <i class="fa-solid fa-star" data-deger="5"></i>
                        </div>
                    </div>

                    <div style="margin-bottom: 20px;">
                        <label style="display: block; margin-bottom: 5px; color: #777; font-size: 0.9rem;">Yorumunuz</label>
                        <textarea name="YorumMetni" rows="4" placeholder="Bu ürün hakkında ne düşünüyorsunuz?" style="width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 6px; outline: none; resize: vertical;"></textarea>
                    </div>

                    <button type="submit" id="yorum-gonder-btn" style="background-color: #e0a6aa; color: white; padding: 12px 30px; border: none; border-radius: 30px; font-weight: bold; cursor: pointer; transition: 0.3s;">
                        Yorumu Gönder
                    </button>
                    <p id="yildiz-hata" style="color: red; font-size: 0.9rem; display: none; margin-top: 10px;">Lütfen puan vermek için yıldızlara tıklayın.</p>
                </form>
            }
            else
            {
                <div style="text-align: center; padding: 20px;">
                    <i class="fa-solid fa-lock" style="font-size: 2rem; color: #e0a6aa; margin-bottom: 15px;"></i>
                    <h4 style="color: #4a3b3b; margin-bottom: 10px;">Yorum Yapabilmek İçin Giriş Yapmalısınız</h4>
                    <p style="color: #777; margin-bottom: 20px;">Bu ürün hakkında düşüncelerinizi paylaşmak için lütfen hesabınıza giriş yapın.</p>
                    <a href="/Account/Login" style="background-color: #4a3b3b; color: white; padding: 10px 25px; border-radius: 30px; text-decoration: none; font-weight: bold;">Giriş Yap / Üye Ol</a>
                </div>
            }
        </div>

        <div class="yorum-listesi">
            @if (ViewBag.Yorumlar != null && ((List<EDITCOWEB.Models.Review>)ViewBag.Yorumlar).Count > 0)
            {
                foreach (var yorum in (List<EDITCOWEB.Models.Review>)ViewBag.Yorumlar)
                {
                    <div class="tekil-yorum" style="border-bottom: 1px solid #f0f0f0; padding: 20px 0;">

                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px;">
                            <strong style="color: #333; font-size: 1.1rem;">@yorum.KullaniciAdi</strong>
                            <span style="color: #aaa; font-size: 0.85rem;">@yorum.Tarih.ToString("dd.MM.yyyy")</span>
                        </div>

                        <div style="color: #e0a6aa; margin-bottom: 12px; font-size: 0.9rem;">
                            @for (int i = 0; i < yorum.Puan; i++)
                            {
                                <span>★</span>
                            }
                            @for (int i = yorum.Puan; i < 5; i++)
                            {
                                <span style="color: #e0e0e0;">★</span>
                            }
                        </div>

                        @if (!string.IsNullOrEmpty(yorum.YorumMetni))
                        {
                            <p style="color: #555; line-height: 1.6; margin: 0;">@yorum.YorumMetni</p>
                        }
                    </div>
                }
            }
            else
            {
                <div style="text-align: center; padding: 30px 0;">
                    <i class="fa-regular fa-comment-dots" style="font-size: 2.5rem; color: #ddd; margin-bottom: 10px;"></i>
                    <p style="color: #888; font-style: italic; margin: 0;">Bu ürün için henüz değerlendirme yapılmamış. İlk yorumu siz yazın!</p>
                </div>
            }
        </div>

    </div>
   

    <div id="toast-kutusu"><i class="fa-solid fa-check"></i> Ürün sepete eklendi!</div>

    <script>
        // Bildirim Fonksiyonu
        function bildirimGoster(mesaj) {
            var x = document.getElementById("toast-kutusu");
            if (mesaj) x.innerHTML = '<i class="fa-solid fa-check"></i> ' + mesaj;
            x.className = "goster";
            setTimeout(function () { x.className = x.className.replace("goster", ""); }, 3000);
        }

        // Sepete Ekleme Fonksiyonu (Artık C# Modelinden doğrudan veri alıyor)
        function sepeteEkle() {
            var sepet = JSON.parse(localStorage.getItem('sepetim')) || [];
            sepet.push({
                ad: "@Html.Raw(Model.UrunAdi)",
                resim: "@Html.Raw(Model.ResimYolu)",
                fiyat: "@Html.Raw(Model.Fiyat.ToString("N0")) TL",
                adet: 1
            });
            localStorage.setItem('sepetim', JSON.stringify(sepet));
            localStorage.setItem('sepetSayisi', sepet.length);
            bildirimGoster("Ürün başarıyla sepete eklendi!");
        }

        // Favorilere Ekleme Fonksiyonu (C# Modelinden veri alıyor)
        function favoriyeEkle() {
            var favoriler = JSON.parse(localStorage.getItem('favorilerim')) || [];
            var baslik = "@Html.Raw(Model.UrunAdi)";

            var varMi = favoriler.find(x => x.ad === baslik);
            if (varMi) {
                bildirimGoster("Bu ürün zaten favorilerinizde ekli! ❤️");
                return;
            }

            favoriler.push({
                ad: baslik,
                resim: "@Html.Raw(Model.ResimYolu)",
                fiyat: "@Html.Raw(Model.Fiyat.ToString("N0")) TL"
            });

            localStorage.setItem('favorilerim', JSON.stringify(favoriler));
            setTimeout(function () { bildirimGoster("Favorilere eklendi! ❤️"); }, 100);
        }

        // ================= İNTERAKTİF YILDIZ SEÇİMİ (HOVER VE TIKLAMA) =================
        const yildizlar = document.querySelectorAll('.yildiz-secici i');
        const puanGizliInput = document.getElementById('secilen-puan');
        const formBtn = document.getElementById('yorum-gonder-btn');
        const hataMesaji = document.getElementById('yildiz-hata');

        if (yildizlar.length > 0) {
            yildizlar.forEach(yildiz => {
                // Farenin üstüne geldiğinde yıldızları boya
                yildiz.addEventListener('mouseover', function () {
                    let hoverDegeri = this.getAttribute('data-deger');
                    yildizlariBoya(hoverDegeri);
                });

                // Fareyi çektiğinde seçili olan puana geri dön
                yildiz.addEventListener('mouseout', function () {
                    let seciliDeger = puanGizliInput.value;
                    yildizlariBoya(seciliDeger);
                });

                // Tıklandığında puanı kaydet
                yildiz.addEventListener('click', function () {
                    puanGizliInput.value = this.getAttribute('data-deger');
                    yildizlariBoya(this.getAttribute('data-deger'));
                    hataMesaji.style.display = 'none'; // Seçim yapıldıysa hatayı gizle
                });
            });

            function yildizlariBoya(deger) {
                yildizlar.forEach(y => {
                    if (y.getAttribute('data-deger') <= deger) {
                        y.style.color = '#f39c12'; // Sarı renk
                    } else {
                        y.style.color = '#ddd'; // Gri renk
                    }
                });
            }

            // Yıldız seçilmeden formun gönderilmesini engelleme
            formBtn.addEventListener('click', function (e) {
                if (puanGizliInput.value == "0") {
                    e.preventDefault(); // Formun gitmesini durdur
                    hataMesaji.style.display = 'block';
                }
            });
        }

        // ================= BAŞARILI YORUM BİLDİRİMİ =================
        @if (TempData["YorumBasarili"] != null)
        {
                <text>
                // Sayfa yüklendikten yarım saniye sonra o şık toast kutunu tetikliyoruz
                setTimeout(function() {
                    bildirimGoster('@TempData["YorumBasarili"]');
                }, 500);
                </text>
        }

    </script>
</body>
</html>
