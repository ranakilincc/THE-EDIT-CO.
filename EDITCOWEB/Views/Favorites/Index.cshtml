@{
    ViewData["Title"] = "Favorilerim";
}

<div class="container" style="
    margin-top: 140px;
    min-height: 400px;
    max-width: 1000px;
    margin-left: auto;
    margin-right: auto;
    width: 90%; /* Mobilde kenarlara yapışmasın diye */
">

    <h2 style="margin-bottom: 30px; font-weight: 300; text-align: center;">FAVORİ ÜRÜNLERİM ❤️</h2>

    <div id="favori-dolu" style="display: none;">
        <table class="table" style="width: 100%; border-collapse: separate; border-spacing: 0 15px;">
            <thead style="display: none;">
                <tr><th>Ürün</th><th>İşlem</th></tr>
            </thead>
            <tbody id="favori-listesi">
            </tbody>
        </table>

        <div style="text-align: right; margin-top: 20px;">
            <button onclick="favorileriTemizle()" class="btn" style="border: 1px solid #e0a6aa; color: white; background: #e0a6aa; border-radius: 20px; padding: 8px 25px;">
                Tümünü Temizle
            </button>
        </div>
    </div>

    <div id="favori-bos" style="display: none; width: 100%;">

        <div style="
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 400px;
        padding: 40px; ">

            <i class="fa-regular fa-heart" style="font-size: 80px; color: #eee; margin-bottom: 25px;"></i>

            <p style="color: #999; font-size: 1.3rem; margin-bottom: 30px;">
                Favori listeniz henüz boş.
            </p>

            <a href="/#urunler" class="btn" style="
            background-color: #e0a6aa;
            color: white;
            border-radius: 30px;
            padding: 15px 50px;
            font-weight: bold;
            text-decoration: none;
            box-shadow: 0 5px 15px rgba(224, 166, 170, 0.4);
            display: inline-block; /* Butonun şeklini korur */">
                Ürünlere Göz At
            </a>

        </div>
    </div>
   
</div>

<script>
    document.addEventListener("DOMContentLoaded", function() {
        favorileriListele();
    });

    function favorileriListele() {
        var favoriler = JSON.parse(localStorage.getItem('favorilerim')) || [];
        var liste = document.getElementById("favori-listesi");

        if (favoriler.length === 0) {
            document.getElementById("favori-dolu").style.display = "none";
            document.getElementById("favori-bos").style.display = "block";
            return;
        }

        document.getElementById("favori-dolu").style.display = "block";
        document.getElementById("favori-bos").style.display = "none";
        liste.innerHTML = "";

        favoriler.forEach(function(urun, index) {
            liste.innerHTML += `
                <tr style="background: white; box-shadow: 0 4px 15px rgba(0,0,0,0.03); border-radius: 15px;">

                    <td style="padding: 20px; border-radius: 15px 0 0 15px; display: flex; align-items: center; gap: 20px;">
                        <img src="${urun.resim}" style="width: 80px; height: 80px; object-fit: cover; border-radius: 10px; border: 1px solid #f0f0f0;">
                        <div>
                            <h5 style="margin: 0; color: #333; font-weight: 600;">${urun.ad}</h5>
                            <div style="color: #e0a6aa; font-weight: bold; margin-top: 5px;">${urun.fiyat}</div>
                        </div>
                    </td>

                    <td style="padding: 20px; text-align: right; vertical-align: middle; border-radius: 0 15px 15px 0;">

                        <button onclick="favoridenSil(${index})" title="Listeden Kaldır" style="background: none; border: none; color: #dc3545; font-size: 1.2rem; margin-left: 15px; cursor: pointer;">
                            <i class="fa-solid fa-trash"></i>
                        </button>
                    </td>
                </tr>
                <tr style="height: 15px;"></tr> `;
        });
    }

    function favoridenSil(index) {
        var favoriler = JSON.parse(localStorage.getItem('favorilerim')) || [];
        favoriler.splice(index, 1);
        localStorage.setItem('favorilerim', JSON.stringify(favoriler));
        favorileriListele();
    }

    function favorileriTemizle() {
        if(confirm("Tüm favorileri silmek istediğine emin misin?")) {
            localStorage.removeItem('favorilerim');
            favorileriListele();
        }
    }
</script>