@model EDITCOWEB.Models.CheckoutViewModel

@{
    ViewData["Title"] = "Ödeme Sayfası";
}

<style>
    .checkout-wrapper {
        margin-top: 50px;
        display: flex;
        justify-content: center;
        padding: 30px 20px 60px 20px;
    }

    .checkout-card {
        width: 100%;
        max-width: 850px;
        background: #fff;
        border-radius: 28px;
        padding: 40px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
    }

    .checkout-title {
        font-size: 2rem;
        font-weight: 700;
        color: #2f2f2f;
        margin-bottom: 30px;
    }

    .checkout-section-title {
        font-size: 1.25rem;
        font-weight: 600;
        color: #3d3d3d;
        margin-bottom: 20px;
    }

    .checkout-form-group {
        margin-bottom: 18px;
    }

    .checkout-label {
        display: block;
        margin-bottom: 8px;
        font-weight: 600;
        color: #4a4a4a;
    }

    .checkout-input,
    .checkout-textarea {
        width: 100%;
        border: 1px solid #e4c7cb;
        border-radius: 14px;
        padding: 14px 16px;
        font-size: 1rem;
        outline: none;
        background-color: #fffafb;
        transition: 0.2s ease;
        box-sizing: border-box;
    }

        .checkout-input:focus,
        .checkout-textarea:focus {
            border-color: #d89aa2;
            box-shadow: 0 0 0 3px rgba(224, 166, 170, 0.18);
        }

    .checkout-textarea {
        min-height: 110px;
        resize: vertical;
    }

    .checkout-row {
        display: flex;
        gap: 16px;
    }

    .checkout-col {
        flex: 1;
    }

    .checkout-divider {
        border: none;
        border-top: 1px solid #f0d9dc;
        margin: 28px 0;
    }

    .checkout-button {
        width: 100%;
        margin-top: 28px;
        background-color: #e0a6aa;
        color: #2d1f21;
        border: none;
        border-radius: 999px;
        padding: 15px;
        font-size: 1.05rem;
        font-weight: 700;
        cursor: pointer;
        transition: 0.2s ease;
        box-shadow: 0 8px 18px rgba(224, 166, 170, 0.28);
    }

        .checkout-button:hover {
            transform: translateY(-2px);
            background-color: #d9969c;
        }

    .field-validation-error {
        color: #c0392b;
        font-size: 0.9rem;
        margin-top: 6px;
        display: block;
    }

    .validation-summary-errors {
        color: #c0392b;
        background: #fff1f1;
        border: 1px solid #f3c5c5;
        padding: 12px 14px;
        border-radius: 12px;
        margin-bottom: 18px;
    }

    @@media (max-width: 768px) {
        .checkout-card {
            padding: 24px;
        }

        .checkout-row {
            flex-direction: column;
            gap: 0;
        }

        .checkout-title {
            font-size: 1.6rem;
        }
    }
</style>

<div class="checkout-wrapper">
    <div class="checkout-card">
        <h2 class="checkout-title">Ödeme Bilgileri</h2>

        <form asp-action="Index" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly"></div>

            <h4 class="checkout-section-title">Teslimat Bilgileri</h4>

            <div class="checkout-form-group">
                <label asp-for="FullName" class="checkout-label">Ad Soyad</label>
                <input asp-for="FullName" class="checkout-input" />
                <span asp-validation-for="FullName"></span>
            </div>

            <div class="checkout-form-group">
                <label asp-for="PhoneNumber" class="checkout-label">Telefon</label>
                <input asp-for="PhoneNumber" class="checkout-input" id="telefonInput" maxlength="11" placeholder="05XX XXX XX XX" />
                <span asp-validation-for="PhoneNumber"></span>
            </div>

            <div class="checkout-form-group">
                <label asp-for="AddressLine" class="checkout-label">Adres</label>
                <textarea asp-for="AddressLine" class="checkout-textarea"></textarea>
                <span asp-validation-for="AddressLine"></span>
            </div>

            <div class="checkout-row">
                <div class="checkout-col">
                    <div class="checkout-form-group">
                        <label asp-for="City" class="checkout-label">Şehir</label>
                        <select asp-for="City" class="checkout-input" style="cursor: pointer;">
                            <option value="" disabled selected>Şehir Seçiniz...</option>
                            <option value="Adana">Adana</option>
                            <option value="Adıyaman">Adıyaman</option>
                            <option value="Afyonkarahisar">Afyonkarahisar</option>
                            <option value="Ağrı">Ağrı</option>
                            <option value="Amasya">Amasya</option>
                            <option value="Ankara">Ankara</option>
                            <option value="Antalya">Antalya</option>
                            <option value="Artvin">Artvin</option>
                            <option value="Aydın">Aydın</option>
                            <option value="Balıkesir">Balıkesir</option>
                            <option value="Bilecik">Bilecik</option>
                            <option value="Bingöl">Bingöl</option>
                            <option value="Bitlis">Bitlis</option>
                            <option value="Bolu">Bolu</option>
                            <option value="Burdur">Burdur</option>
                            <option value="Bursa">Bursa</option>
                            <option value="Çanakkale">Çanakkale</option>
                            <option value="Çankırı">Çankırı</option>
                            <option value="Çorum">Çorum</option>
                            <option value="Denizli">Denizli</option>
                            <option value="Diyarbakır">Diyarbakır</option>
                            <option value="Edirne">Edirne</option>
                            <option value="Elazığ">Elazığ</option>
                            <option value="Erzincan">Erzincan</option>
                            <option value="Erzurum">Erzurum</option>
                            <option value="Eskişehir">Eskişehir</option>
                            <option value="Gaziantep">Gaziantep</option>
                            <option value="Giresun">Giresun</option>
                            <option value="Gümüşhane">Gümüşhane</option>
                            <option value="Hakkari">Hakkari</option>
                            <option value="Hatay">Hatay</option>
                            <option value="Isparta">Isparta</option>
                            <option value="Mersin">Mersin</option>
                            <option value="İstanbul">İstanbul</option>
                            <option value="İzmir">İzmir</option>
                            <option value="Kars">Kars</option>
                            <option value="Kastamonu">Kastamonu</option>
                            <option value="Kayseri">Kayseri</option>
                            <option value="Kırklareli">Kırklareli</option>
                            <option value="Kırşehir">Kırşehir</option>
                            <option value="Kocaeli">Kocaeli</option>
                            <option value="Konya">Konya</option>
                            <option value="Kütahya">Kütahya</option>
                            <option value="Malatya">Malatya</option>
                            <option value="Manisa">Manisa</option>
                            <option value="Kahramanmaraş">Kahramanmaraş</option>
                            <option value="Mardin">Mardin</option>
                            <option value="Muğla">Muğla</option>
                            <option value="Muş">Muş</option>
                            <option value="Nevşehir">Nevşehir</option>
                            <option value="Niğde">Niğde</option>
                            <option value="Ordu">Ordu</option>
                            <option value="Rize">Rize</option>
                            <option value="Sakarya">Sakarya</option>
                            <option value="Samsun">Samsun</option>
                            <option value="Siirt">Siirt</option>
                            <option value="Sinop">Sinop</option>
                            <option value="Sivas">Sivas</option>
                            <option value="Tekirdağ">Tekirdağ</option>
                            <option value="Tokat">Tokat</option>
                            <option value="Trabzon">Trabzon</option>
                            <option value="Tunceli">Tunceli</option>
                            <option value="Şanlıurfa">Şanlıurfa</option>
                            <option value="Uşak">Uşak</option>
                            <option value="Van">Van</option>
                            <option value="Yozgat">Yozgat</option>
                            <option value="Zonguldak">Zonguldak</option>
                            <option value="Aksaray">Aksaray</option>
                            <option value="Bayburt">Bayburt</option>
                            <option value="Karaman">Karaman</option>
                            <option value="Kırıkkale">Kırıkkale</option>
                            <option value="Batman">Batman</option>
                            <option value="Şırnak">Şırnak</option>
                            <option value="Bartın">Bartın</option>
                            <option value="Ardahan">Ardahan</option>
                            <option value="Iğdır">Iğdır</option>
                            <option value="Yalova">Yalova</option>
                            <option value="Karabük">Karabük</option>
                            <option value="Kilis">Kilis</option>
                            <option value="Osmaniye">Osmaniye</option>
                            <option value="Düzce">Düzce</option>
                        </select>
                        <span asp-validation-for="City"></span>
                    </div>
                </div>

                <div class="checkout-col">
                    <div class="checkout-form-group">
                        <label asp-for="PostalCode" class="checkout-label">Posta Kodu</label>
                        <input asp-for="PostalCode" class="checkout-input" />
                        <span asp-validation-for="PostalCode"></span>
                    </div>
                </div>
            </div>

            <hr class="checkout-divider" />

            <h4 class="checkout-section-title">Kart Bilgileri</h4>

            <div class="checkout-form-group">
                <label asp-for="CardHolderName" class="checkout-label">Kart Üzerindeki İsim</label>
                <input asp-for="CardHolderName" class="checkout-input" id="kartIsimInput" placeholder="AD SOYAD" />
                <span asp-validation-for="CardHolderName"></span>
            </div>

            <div class="checkout-form-group">
                <label asp-for="CardNumber" class="checkout-label">Kart Numarası</label>
                <input asp-for="CardNumber" class="checkout-input" id="kartNoInput" maxlength="19" placeholder="0000 0000 0000 0000" />
                <span asp-validation-for="CardNumber"></span>
            </div>

            <div class="checkout-row">
                <div class="checkout-col">
                    <div class="checkout-form-group">
                        <label asp-for="ExpiryDate" class="checkout-label">Son Kullanma Tarihi</label>
                        <input asp-for="ExpiryDate" class="checkout-input" id="tarihInput" maxlength="5" placeholder="AA/YY" />
                        <span asp-validation-for="ExpiryDate"></span>
                    </div>
                </div>

                <div class="checkout-col">
                    <div class="checkout-form-group">
                        <label asp-for="CVV" class="checkout-label">CVV</label>
                        <input asp-for="CVV" class="checkout-input" id="cvvInput" maxlength="3" placeholder="000" />
                        <span asp-validation-for="CVV"></span>
                    </div>
                </div>
            </div>

            <div class="taksit-secenekleri" style="margin-top: 20px;">
                <label style="font-weight: bold; display: block; margin-bottom: 10px;">Taksit Seçenekleri</label>
                <select class="form-control" style="width: 100%; padding: 10px; border-radius: 5px; border: 1px solid #ddd;">
                    <option value="1">Tek Çekim</option>
                    <option value="2">2 Taksit (Vade Farksız)</option>
                    <option value="3">3 Taksit (%3 İndirimli!)</option>
                    <option value="6">6 Taksit</option>
                </select>
            </div>

            <div style="margin-top: 20px; padding: 15px; background-color: #f9f9f9; border-radius: 10px; border: 1px solid #eee; text-align: right;">
                <span style="font-size: 1.1rem; color: #555;">Toplam Ödenecek Tutar:</span>
                <span id="checkout-final-price" style="font-size: 1.5rem; font-weight: bold; color: black; margin-left: 10px;">0.00 TL</span>
            </div>


            <button type="submit" class="checkout-button">
                Siparişi Tamamla
            </button>
        </form>
    </div>
</div>


<script>
    document.addEventListener("DOMContentLoaded", function() {
        // Sepet sayfasından gelen veriyi çek
        const tutar = localStorage.getItem("odenecekTutar") || localStorage.getItem("indirimliToplam");

        // İŞTE BURAYI DÜZELTTİK: HTML'deki doğru ID'yi (checkout-final-price) yazdık
        const tutarGosterge = document.getElementById("checkout-final-price");

        if (tutar && tutarGosterge) {
            // Gelen veriyi sayıya çevirip 2 basamaklı formatla gösterelim
            const sayiTutar = parseFloat(tutar);
            if (!isNaN(sayiTutar)) {
                tutarGosterge.innerText = sayiTutar.toFixed(2).replace(".", ",") + " TL";
            }
        }
    });
</script>




<script>
    document.addEventListener("DOMContentLoaded", function () {

        // 1. TELEFON: Sadece rakam ve maksimum 11 hane
        const telefonInput = document.getElementById('telefonInput');
        if (telefonInput) {
            telefonInput.addEventListener('input', function (e) {
                this.value = this.value.replace(/[^0-9]/g, ''); // Harfleri anında siler
            });
        }

        // 2. KART NUMARASI: Sadece rakam ve her 4 rakamda bir boşluk
        const kartNoInput = document.getElementById('kartNoInput');
        if (kartNoInput) {
            kartNoInput.addEventListener('input', function (e) {
                // Önce tüm boşlukları ve harfleri temizle
                let value = this.value.replace(/\D/g, '');
                // Sonra her 4 rakamda bir boşluk ekle
                value = value.replace(/(.{4})/g, '$1 ').trim();
                this.value = value;
            });
        }

        // 3. SON KULLANMA TARİHİ (Ay/Yıl): Sadece rakam ve araya '/' koyma
        const tarihInput = document.getElementById('tarihInput');
        if (tarihInput) {
            tarihInput.addEventListener('input', function (e) {
                let value = this.value.replace(/\D/g, ''); // Sadece rakamları al

                if (value.length > 2) {
                    // İlk 2 rakamı al, araya '/' koy, kalanları ekle
                    value = value.substring(0, 2) + '/' + value.substring(2, 4);
                }
                this.value = value;
            });
        }

        // 4. CVV: Sadece rakam ve maksimum 3 hane
        const cvvInput = document.getElementById('cvvInput');
        if (cvvInput) {
            cvvInput.addEventListener('input', function (e) {
                this.value = this.value.replace(/[^0-9]/g, '');
            });
        }
    });



                    // 5. KART ÜZERİNDEKİ İSİM: Sadece harf ve boşluk (Rakamları ve sembolleri engeller)
        const kartIsimInput = document.getElementById('kartIsimInput');
        if (kartIsimInput) {
            kartIsimInput.addEventListener('input', function (e) {
                // Sadece Türkçe/İngilizce harfler ve boşluk karakterine izin verir, diğer her şeyi siler
                let value = this.value.replace(/[^a-zA-ZğüşıöçĞÜŞİÖÇ\s]/g, '');

                // Kart üzerindeki isimler genelde büyük harf olur, otomatik büyütelim:
                this.value = value.toLocaleUpperCase('tr-TR');
            });
        }

</script>

